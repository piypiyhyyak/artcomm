# Root-only secrets file for CMS auth.
# Copy to /etc/artcomm-cms.env and set permissions:
#   sudo install -m 600 -o root -g root deploy/systemd/artcomm-cms.env.example /etc/artcomm-cms.env
#
# Required for production:
ARTCOMM_CMS_ADMIN_LOGIN=admin
ARTCOMM_CMS_ADMIN_PASSWORD=change-this-strong-password
# Требование к паролю: минимум 10 символов, буквы и цифры
ARTCOMM_CMS_SECURITY_CODEWORD=change-this-codeword
# Рекомендуется случайная строка 32+ символов (pepper для усиления scrypt-хешей)
ARTCOMM_CMS_PASSWORD_PEPPER=change-this-long-random-pepper
# В production оставляйте true: без секретов сервис не поднимется
ARTCOMM_CMS_REQUIRE_ENV_SECRETS=true

# Optional: можно хранить предрасчитанные хеши вместо plain-секретов.
# If ARTCOMM_CMS_ADMIN_PASSWORD is set, it has priority over hash.
# ARTCOMM_CMS_ADMIN_PASSWORD_HASH=
# ARTCOMM_CMS_SECURITY_CODEWORD_HASH=
# ARTCOMM_CMS_VERSION_LIMIT=30

# Contact form delivery mode:
# - smtp: send real emails via SMTP
# - log: write submissions to cms-data/contact-submissions.jsonl (fallback/dev mode)
ARTCOMM_CONTACT_MODE=smtp
ARTCOMM_CONTACT_TO=info@artcommrf.ru
ARTCOMM_CONTACT_CC=
ARTCOMM_CONTACT_FROM="АртКомм <no-reply@artcomminstitute.ru>"
ARTCOMM_CONTACT_SMTP_HOST=smtp.yandex.ru
ARTCOMM_CONTACT_SMTP_PORT=465
ARTCOMM_CONTACT_SMTP_SECURE=true
ARTCOMM_CONTACT_SMTP_USER=mailer@artcomminstitute.ru
ARTCOMM_CONTACT_SMTP_PASS=change-this-mail-password
